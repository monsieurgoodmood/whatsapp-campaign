# TWILIO CREDENTIALS
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here_from_twilio_console
TWILIO_WHATSAPP_NUMBER=+XXXXXXXXXXXXX

# WHATSAPP MESSAGE TEMPLATES - NOEL 2025
TEMPLATE_A_SID=your_template_a_sid_here
TEMPLATE_B_SID=your_template_b_sid_here
TEMPLATE_C_SID=your_template_c_sid_here

# WHATSAPP MESSAGE TEMPLATES - PRINTEMPS/ÉTÉ 2026
TEMPLATE_ETE_A_SID=your_template_ete_a_sid_here
TEMPLATE_ETE_B_SID=your_template_ete_b_sid_here

# CAMPAIGN PARAMETERS - NOEL 2025
CAMPAIGN_NAME=noel2025
PROMO_CODE=NOEL15
CAMPAIGN_URL=https://www.elit-parking.fr/

# CAMPAIGN PARAMETERS - PRINTEMPS/ÉTÉ 2026
CAMPAIGN_NAME_ETE=printemps_ete_2026
PROMO_CODE_ETE=PRINTEMPS2026
PROMO_DISCOUNT_ETE=15
CAMPAIGN_URL_ETE=https://www.elit-parking.fr/

# RATE LIMITING & SAFETY
RATE_LIMIT=10
TEST_MODE=true
TEST_LIMIT=5

# LOGGING
LOG_LEVEL=INFO
VERBOSE_LOGGING=false